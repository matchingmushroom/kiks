rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users: only self or admin can modify ──
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ── Sales: prevent price manipulation ──
    match /sales/{saleId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      // Optional: validate finalAmount == totalAmount - discountAmount
      // allow create, update: if request.auth != null
      //   && request.resource.data.finalAmount == request.resource.data.totalAmount - request.resource.data.discountAmount;
    }

    // ── Products: read public, write authenticated ──
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Categories: read public, write authenticated ──
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Orders: read public (for cart checkout), write authenticated ──
    match /orders/{orderId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Invoices: read public (for public invoice view) ──
    match /invoices/{invoiceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Coupons: read authenticated (used in checkout) ──
    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Debtors: read authenticated, write authenticated ──
    match /debtors/{debtorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Homepage sections: read public, write authenticated ──
    match /homepage_sections/{sectionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Settings: read public (shop name, etc.), write authenticated ──
    match /shop_settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Inventory logs ──
    match /inventory_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── FIFO layers ──
    match /fifo_layers/{layerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Rate limits ──
    match /_rateLimits/{key} {
      allow read, write: if request.auth != null;
    }

    // ── Testimonials: read public, write authenticated ──
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Purchases ──
    match /purchases/{purchaseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Expenses ──
    match /expenses/{expenseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Recurring expenses ──
    match /recurring_expenses/{expenseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Accounts ──
    match /accounts/{accountId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Account transactions ──
    match /account_transactions/{txnId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Journal entries ──
    match /journalEntries/{entryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Creditors ──
    match /creditors/{creditorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Suppliers ──
    match /suppliers/{supplierId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Offers ──
    match /offers/{offerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Counters (auto-increment) ──
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Loyalty transactions ──
    match /loyalty_transactions/{txnId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Sections (homepage builder) ──
    match /sections/{sectionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Catch-all: deny everything not explicitly allowed ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
